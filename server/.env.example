# MongoDB connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/vcardtn?retryWrites=true&w=majority

# Server port
PORT=5000

# Admin token for protected routes (delete/update appointments)
ADMIN_TOKEN=your_secure_random_token_here

# Telegram notifications (optional - for instant phone alerts on new bookings)
# 1. Create bot with @BotFather, get token
# 2. Get your chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxyz
TELEGRAM_CHAT_ID=123456789

# Top-up notifications (optional - use separate bot for recharge requests)
# If not set, will use the same bot as bookings
TOPUP_TELEGRAM_BOT_TOKEN=8747105508:AAEzW9PoxzkMTQ38DovpOnI3krgrFkH8MZ0
TOPUP_TELEGRAM_CHAT_ID=7654060384
