# Copy to .env and fill with YOUR OWN values. Never commit .env.

# MongoDB (get a free cluster at mongodb.com/atlas)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/yourdb

PORT=5000

# Strong random secret for admin dashboard (e.g. run: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
ADMIN_TOKEN=your-long-random-secret-here

# Optional: restrict CORS to your frontend (comma-separated for multiple)
# CORS_ORIGIN=https://yoursite.com,https://www.yoursite.com
